# NVIDIA NIM API Key (primary brain + vision via build.nvidia.com — free tier)
# Format: nvapi-...
NVIDIA_API_KEY=nvapi-your_key
# Optional model overrides:
NIM_REASONING_MODEL=meta/llama-3.3-70b-instruct
NIM_VISION_MODEL=nvidia/nemotron-nano-12b-v2-vl
NIM_OMNI_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning

# Sarvam AI API Key (for Indian context STT/TTS)
SARVAM_API_KEY=your_sarvam_api_key

# Groq API Keys (Primary and Rotation Pool)
GROQ_API_KEY=gsk_your_primary_key
GROQ_API_KEY_2=gsk_optional_rotation_key_1
GROQ_API_KEY_3=gsk_optional_rotation_key_2

# Google Gemini API Key
GEMINI_API_KEY=AIzaSy_your_gemini_key
GEMINI_MODEL=gemini-3-flash

# OpenRouter API Key (for fallback models and reasoning)
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key
